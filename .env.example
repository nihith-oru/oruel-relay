# --- Server ---
PORT=4000
NODE_ENV=development

# --- Database ---
# Postgres connection string used by Prisma
DATABASE_URL="postgresql://oruel:oruel_password@localhost:5432/oruel_relay?schema=public"

# --- Spheron AI (Oru'el's real, official partner API key) ---
# NEVER share this key with Podstack or anyone downstream.
# Generate from https://app.spheron.ai/settings
SPHERON_API_KEY="sph_xxxxxxxxxxxxxxxxxxxxxxxx"
SPHERON_BASE_URL="https://app.spheron.ai"

# --- Markup ---
# Fallback/default markup percentage if none exists yet in the Settings table.
# Real value is stored in DB and editable live from the admin dashboard.
DEFAULT_MARKUP_PERCENT=20

# --- Admin dashboard ---
# Used only by scripts/seed-admin.ts to create the first admin login.
ADMIN_SEED_USERNAME="admin"
ADMIN_SEED_PASSWORD="change-me-immediately"

# Cost poller interval (ms) - how often we refresh running deployment costs from Spheron
COST_POLL_INTERVAL_MS=300000
